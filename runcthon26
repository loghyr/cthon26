#
# runcthon26 -- one-stop driver that runs BOTH halves of cthon26 in
# sequence and prints a combined summary.  Does not modify cthon04's
# own drivers (per the preservation rule in AGENTS.md); it just
# invokes them in turn, then invokes nfsv42-tests/runtests.
#
# Usage:
#   ./runcthon26 [-d MOUNTPOINT] [-t|-f] [--skip-cthon04] [--skip-nfsv42]
#                [--tap]
#
#   -d MOUNTPOINT   NFS mount point (default: current directory).
#                   Passed to cthon04 as NFSTESTDIR via tests.init
#                   mechanism, and to nfsv42-tests as -d.
#   -t              cthon04 timing mode (default).
#   -f              cthon04 functional-only mode.
#   --skip-cthon04  skip the classic groups (nfsv42 only).
#   --skip-nfsv42   skip the NFSv4.x tests (cthon04 only).
#   --tap           emit TAP13 aggregate output instead of the
#                   classic "=== ... ===" banner format.
#
# The cthon04 half runs the four groups basic/general/special/lock
# via their own runtests scripts (not modified).  The nfsv42-tests
# half runs via nfsv42-tests/runtests.
#
# Exit status: worst of the two halves.
#   0   all PASS or SKIP
#   1   at least one FAIL
#   98  at least one test binary missing
#   99  at least one BUG

set -eu

HERE=$(cd "$(dirname "$0")" && pwd)
MOUNT="."
TESTARG="-t"
SKIP_CTHON04=0
SKIP_NFSV42=0
TAP=0

usage() {
    sed -n '4,30p' "$0" | sed 's/^# \{0,1\}//'
}

while [ $# -gt 0 ]; do
    case "$1" in
        -d) [ $# -ge 2 ] || { echo "runcthon26: -d requires an argument" >&2; exit 2; }
            MOUNT="$2"; shift 2;;
        -t) TESTARG="-t"; shift;;
        -f) TESTARG="-f"; shift;;
        --skip-cthon04) SKIP_CTHON04=1; shift;;
        --skip-nfsv42)  SKIP_NFSV42=1;  shift;;
        --tap) TAP=1; shift;;
        -h|--help) usage; exit 0;;
        *)  echo "runcthon26: unknown argument: $1" >&2; exit 2;;
    esac
done

# Resolve MOUNT to an absolute path so that cthon04's `cd basic;
# sh runtests $TESTARG` still finds it.
case "$MOUNT" in
    /*) ;;
    *)  MOUNT=$(cd "$MOUNT" && pwd);;
esac

cthon04_worst=0
nfsv42_worst=0

# --- cthon04 half --------------------------------------------------------

run_cthon04() {
    # cthon04's runtests expects either positional args or
    # tests.init to be sourced.  We pass "-a $TESTARG $MOUNT" which
    # matches the 3-positional form (TESTS TESTARG TESTPATH) and
    # does not touch the cthon04 runtests source.
    set +e
    (cd "$HERE" && sh ./runtests -a "$TESTARG" "$MOUNT")
    cthon04_worst=$?
    set -e
}

run_cthon04_tap() {
    # Use the TAP wrapper for the cthon04 side.
    set +e
    "$HERE/cthon04-tap" -d "$MOUNT" -a "$TESTARG"
    cthon04_worst=$?
    set -e
}

# --- nfsv42-tests half ---------------------------------------------------

run_nfsv42() {
    set +e
    "$HERE/nfsv42-tests/runtests" -d "$MOUNT"
    nfsv42_worst=$?
    set -e
}

run_nfsv42_tap() {
    set +e
    "$HERE/nfsv42-tests/runtests" --tap -d "$MOUNT"
    nfsv42_worst=$?
    set -e
}

# --- driver --------------------------------------------------------------

if [ $TAP -eq 1 ]; then
    # Two separate TAP streams concatenated.  Each emits its own
    # "TAP version 13" + "1..N" so `prove` can consume them as
    # sequential inputs via `prove --exec cat tap-file`, or a
    # tester can pipe the combined stream into a TAP-aware log.
    [ $SKIP_CTHON04 -eq 1 ] || run_cthon04_tap
    [ $SKIP_NFSV42 -eq 1 ]  || run_nfsv42_tap
else
    printf '\n======== cthon26 ========\n'
    printf 'Mount: %s    Mode: %s\n\n' "$MOUNT" "$TESTARG"
    if [ $SKIP_CTHON04 -eq 0 ]; then
        printf '%s\n' '--- cthon04 (basic/general/special/lock) ---'
        run_cthon04
        printf '\n'
    fi
    if [ $SKIP_NFSV42 -eq 0 ]; then
        printf '%s\n' '--- nfsv42-tests (NFSv4 / 4.1 / 4.2 syscall-level) ---'
        run_nfsv42
        printf '\n'
    fi
    printf '======== summary ========\n'
    printf '  cthon04:       exit %d\n' "$cthon04_worst"
    printf '  nfsv42-tests:  exit %d\n' "$nfsv42_worst"
fi

# Exit with the worst result across the two halves.
if [ $cthon04_worst -gt $nfsv42_worst ]; then
    exit $cthon04_worst
fi
exit $nfsv42_worst
