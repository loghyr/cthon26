# SPDX-FileCopyrightText: 2026 Tom Haynes <loghyr@gmail.com>
# SPDX-License-Identifier: BSD-2-Clause OR GPL-2.0-only
#
# runcthon26 -- one-stop driver that runs BOTH halves of cthon26 in
# sequence and prints a combined summary.  Does not modify cthon04's
# own drivers (per the preservation rule in AGENTS.md); it just
# invokes them in turn, then invokes nfsv42-tests/runtests.
#
# Usage:
#   ./runcthon26 [-d MOUNTPOINT] [-t|-f] [--skip-cthon04] [--skip-nfsv42]
#                [--tap]
#
#   -d MOUNTPOINT   NFS mount point (default: current directory).
#                   Passed to cthon04 as NFSTESTDIR via tests.init
#                   mechanism, and to nfsv42-tests as -d.
#   -t              cthon04 timing mode (default).
#   -f              cthon04 functional-only mode.
#   --skip-cthon04  skip the classic groups (nfsv42 only).
#   --skip-nfsv42   skip the NFSv4.x tests (cthon04 only).
#   --tap           emit TAP13 aggregate output instead of the
#                   classic "=== ... ===" banner format.
#
# The cthon04 half runs the four groups basic/general/special/lock
# via their own runtests scripts (not modified).  The nfsv42-tests
# half runs via nfsv42-tests/runtests.
#
# Exit status: worst of the two halves.
#   0   all PASS or SKIP
#   1   at least one FAIL
#   98  at least one test binary missing
#   99  at least one BUG

set -eu

HERE=$(cd "$(dirname "$0")" && pwd)
MOUNT="."
TESTARG="-t"
SKIP_CTHON04=0
SKIP_NFSV42=0
TAP=0

usage() {
    sed -n '4,30p' "$0" | sed 's/^# \{0,1\}//'
}

while [ $# -gt 0 ]; do
    case "$1" in
        -d) [ $# -ge 2 ] || { echo "runcthon26: -d requires an argument" >&2; exit 2; }
            MOUNT="$2"; shift 2;;
        -t) TESTARG="-t"; shift;;
        -f) TESTARG="-f"; shift;;
        --skip-cthon04) SKIP_CTHON04=1; shift;;
        --skip-nfsv42)  SKIP_NFSV42=1;  shift;;
        --tap) TAP=1; shift;;
        -h|--help) usage; exit 0;;
        *)  echo "runcthon26: unknown argument: $1" >&2; exit 2;;
    esac
done

# Resolve MOUNT to an absolute path so that cthon04's `cd basic;
# sh runtests $TESTARG` still finds it.
case "$MOUNT" in
    /*) ;;
    *)  MOUNT=$(cd "$MOUNT" && pwd);;
esac

cthon04_worst=0
nfsv42_worst=0

# --- cthon04 half --------------------------------------------------------

run_cthon04() {
    # cthon04's runtests expects either positional args or
    # tests.init to be sourced.  We pass "-a $TESTARG $MOUNT" which
    # matches the 3-positional form (TESTS TESTARG TESTPATH) and
    # does not touch the cthon04 runtests source.
    set +e
    (cd "$HERE" && sh ./runtests -a "$TESTARG" "$MOUNT")
    cthon04_worst=$?
    set -e
}

run_cthon04_tap() {
    # Use the TAP wrapper for the cthon04 side.
    set +e
    "$HERE/cthon04-tap" -d "$MOUNT" -a "$TESTARG"
    cthon04_worst=$?
    set -e
}

# --- nfsv42-tests half ---------------------------------------------------

run_nfsv42() {
    set +e
    "$HERE/nfsv42-tests/runtests" -d "$MOUNT"
    nfsv42_worst=$?
    set -e
}

run_nfsv42_tap() {
    set +e
    "$HERE/nfsv42-tests/runtests" --tap -d "$MOUNT"
    nfsv42_worst=$?
    set -e
}

# --- driver --------------------------------------------------------------

if [ $TAP -eq 1 ]; then
    #
    # Emit ONE coherent TAP13 stream that combines both halves.
    # Each half's TAP output is captured to a temp file, their
    # "TAP version 13" and "1..N" plan lines are stripped, and the
    # nfsv42-tests half's test numbers are renumbered to continue
    # from where the cthon04 half left off.  A single parent
    # "TAP version 13" line starts the stream and a single "1..N"
    # plan ends it.  `prove -e cat` can consume the result directly
    # without parse errors.
    #
    tap1=$(mktemp 2>/dev/null || mktemp -t cthon04-tap.XXXXXX)
    tap2=$(mktemp 2>/dev/null || mktemp -t nfsv42-tap.XXXXXX)
    trap 'rm -f "$tap1" "$tap2"' EXIT

    if [ $SKIP_CTHON04 -eq 0 ]; then
        set +e
        "$HERE/cthon04-tap" -d "$MOUNT" -a "$TESTARG" > "$tap1" 2>&1
        cthon04_worst=$?
        set -e
    fi
    if [ $SKIP_NFSV42 -eq 0 ]; then
        set +e
        "$HERE/nfsv42-tests/runtests" --tap -d "$MOUNT" > "$tap2" 2>&1
        nfsv42_worst=$?
        set -e
    fi

    # grep -c with zero matches prints "0" AND exits 1.  Suppress
    # the non-zero exit with "|| true" (not "|| echo 0" which
    # would append a second "0" and break the arithmetic).
    n1=$(grep -cE '^(ok|not ok) [0-9]+' "$tap1" 2>/dev/null || true)
    n2=$(grep -cE '^(ok|not ok) [0-9]+' "$tap2" 2>/dev/null || true)
    : "${n1:=0}"
    : "${n2:=0}"
    total=$((n1 + n2))

    printf 'TAP version 13\n'
    printf '# cthon26 under %s (TESTARG=%s)\n' "$MOUNT" "$TESTARG"
    printf '1..%d\n' "$total"

    # cthon04 half: strip "TAP version" and "1..N" plan lines, keep
    # everything else (test numbering already starts at 1).
    if [ $SKIP_CTHON04 -eq 0 ]; then
        grep -vE '^TAP version|^1\.\.' "$tap1" || true
    fi

    # nfsv42 half: same strip, plus renumber test IDs to continue
    # from n1+1.  awk renumbers lines matching "^ok NN" or
    # "^not ok NN" by adding the offset; anything else passes
    # through unchanged.
    if [ $SKIP_NFSV42 -eq 0 ]; then
        awk -v offset="$n1" '
            /^TAP version/ || /^1\.\./ { next }
            /^ok [0-9]+ / {
                sub(/^ok [0-9]+/, "ok " ($2 + offset))
                print
                next
            }
            /^not ok [0-9]+ / {
                sub(/^not ok [0-9]+/, "not ok " ($3 + offset))
                print
                next
            }
            { print }
        ' "$tap2"
    fi
else
    printf '\n======== cthon26 ========\n'
    printf 'Mount: %s    Mode: %s\n\n' "$MOUNT" "$TESTARG"
    if [ $SKIP_CTHON04 -eq 0 ]; then
        printf '%s\n' '--- cthon04 (basic/general/special/lock) ---'
        run_cthon04
        printf '\n'
    fi
    if [ $SKIP_NFSV42 -eq 0 ]; then
        printf '%s\n' '--- nfsv42-tests (NFSv4 / 4.1 / 4.2 syscall-level) ---'
        run_nfsv42
        printf '\n'
    fi
    printf '======== summary ========\n'
    printf '  cthon04:       exit %d\n' "$cthon04_worst"
    printf '  nfsv42-tests:  exit %d\n' "$nfsv42_worst"
fi

# Exit with the worst result across the two halves.
if [ $cthon04_worst -gt $nfsv42_worst ]; then
    exit $cthon04_worst
fi
exit $nfsv42_worst
