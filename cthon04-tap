#!/bin/sh
# SPDX-FileCopyrightText: 2026 Tom Haynes <loghyr@gmail.com>
# SPDX-License-Identifier: BSD-2-Clause OR GPL-2.0-only
#
# cthon04-tap -- wrap cthon04 test groups (basic/, general/, special/,
# lock/) and emit aggregate TAP13.
#
# Each of the four groups becomes one TAP test result based on the
# exit status of the group's runtests script.  The group's full
# output is captured and re-emitted as "#"-prefixed diagnostic lines
# so the stream stays valid TAP and any test-level failure messages
# remain visible to prove / tappy.
#
# Usage:
#   ./cthon04-tap [-d SCRATCH] [-a TESTARG] [group ...]
#
#   -d SCRATCH   scratch directory the tests operate under.  A
#                per-group sub-directory is created beneath it.
#                Default: /tmp/cthon04-scratch
#   -a TESTARG   argument passed to each group's runtests (and thence
#                to each test binary).  cthon04 convention: "-t"
#                selects the test-mode harness.  Default: "-t".
#   group        one or more of basic general special lock.  Default:
#                all four in the traditional order.
#
# cthon04 test groups have ordering dependencies within a group (e.g.
# basic/test1 builds a tree, basic/test2 removes it), so each group
# must run sequentially.  The four groups themselves can be run in
# any order but the scratch sub-dir layout keeps them isolated.
#
# Per-group exit codes reflect the group's runtests script.  Exit 0
# means every test in the group passed.  Any non-zero exit is
# reported as "not ok N - cthon04/group # exit K" in the aggregate
# TAP stream.

set -eu

HERE=$(cd "$(dirname "$0")" && pwd)
SCRATCH="/tmp/cthon04-scratch"
TESTARG="-t"
SELECTED=""

#
# Clean up per-group scratch sub-directories on any exit (normal,
# interrupt, or error).  Without this trap, Ctrl-C leaves
# $SCRATCH/<group>.$$ dirs behind, which accumulate over multiple
# aborted runs.  Only touches directories created by THIS process
# (matched via the $$ suffix) so other cthon04-tap invocations are
# not affected.
#
cleanup() {
    rm -rf "$SCRATCH"/*."$$" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

usage() {
    sed -n '4,30p' "$0" | sed 's/^# \{0,1\}//'
}

while [ $# -gt 0 ]; do
    case "$1" in
        -d) [ $# -ge 2 ] || { echo "cthon04-tap: -d requires an argument" >&2; exit 2; }
            SCRATCH="$2"; shift 2;;
        -a) [ $# -ge 2 ] || { echo "cthon04-tap: -a requires an argument" >&2; exit 2; }
            TESTARG="$2"; shift 2;;
        -h|--help) usage; exit 0;;
        basic|general|special|lock)
            SELECTED="$SELECTED $1"; shift;;
        *)  echo "cthon04-tap: unknown argument: $1" >&2; exit 2;;
    esac
done

[ -n "$SELECTED" ] || SELECTED="basic general special lock"

mkdir -p "$SCRATCH"

# Count groups and emit the TAP plan.
n=0
for g in $SELECTED; do n=$((n + 1)); done

printf 'TAP version 13\n'
printf '1..%d\n' "$n"
printf '# cthon04 under %s (TESTARG=%s)\n' "$SCRATCH" "$TESTARG"

i=0
worst=0
for g in $SELECTED; do
    i=$((i + 1))
    if [ ! -x "$HERE/$g/runtests" ]; then
        printf 'not ok %d - cthon04/%s # MISS runtests missing\n' "$i" "$g"
        if [ $worst -lt 98 ]; then worst=98; fi
        continue
    fi
    GROUP_DIR="$SCRATCH/$g.$$"
    mkdir -p "$GROUP_DIR"
    tmp=$(mktemp 2>/dev/null || mktemp -t cthon04.XXXXXX)
    set +e
    (
        cd "$HERE/$g" || exit 98
        NFSTESTDIR="$GROUP_DIR" ./runtests "$TESTARG"
    ) > "$tmp" 2>&1
    rc=$?
    set -e
    if [ $rc -eq 0 ]; then
        printf 'ok %d - cthon04/%s\n' "$i" "$g"
    else
        printf 'not ok %d - cthon04/%s # exit %d\n' "$i" "$g" "$rc"
        if [ $worst -lt 1 ]; then worst=1; fi
    fi
    # Prefix captured output with "# " to preserve TAP validity.
    sed 's/^/# /' "$tmp"
    rm -f "$tmp"
    rm -rf "$GROUP_DIR"
done

exit "$worst"
